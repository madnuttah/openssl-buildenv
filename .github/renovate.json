{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["every weekday", "on saturday"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)versions/openssl\\.txt$"],
      "matchStrings": [
        "(?<currentValue>openssl-[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "extractVersionTemplate": "^openssl-(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)versions/ngtcp2\\.txt$"],
      "matchStrings": [
        "v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "ngtcp2",
      "packageNameTemplate": "ngtcp2/ngtcp2",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)versions/nghttp3\\.txt$"],
      "matchStrings": [
        "v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "nghttp3",
      "packageNameTemplate": "ngtcp2/nghttp3",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)versions/openssl-quic-buildenv\\.txt$"],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)versions/openssl-quic-buildenv\\.txt$"],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-quic-subversion",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)versions/openssl-buildenv\\.txt$"],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)versions/openssl-buildenv\\.txt$"],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-openssl-subversion",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "matchFileNames": ["versions/openssl.txt"],
      "matchDepNames": ["openssl"],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchFileNames": ["versions/ngtcp2.txt"],
      "matchDepNames": ["ngtcp2"],
      "allowedVersions": "<2.0.0"
    },
    {
      "matchFileNames": ["versions/nghttp3.txt"],
      "matchDepNames": ["nghttp3"],
      "allowedVersions": "<2.0.0"
    },
    {
      "groupName": "QUIC stack",
      "matchFileNames": [
        "versions/ngtcp2.txt",
        "versions/nghttp3.txt"
      ],
      "automerge": true
    },
    {
      "description": "Increment QUIC subversion when QUIC deps update",
      "matchFileNames": ["versions/openssl-quic-buildenv.txt"],
      "matchDepNames": ["ngtcp2", "nghttp3"],
      "semanticCommitType": "fix"
    },
    {
      "description": "Increment OpenSSL buildenv subversion on manual or dependency changes",
      "matchFileNames": ["versions/openssl-buildenv.txt"],
      "semanticCommitType": "fix"
    }
  ]
}
