{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],

  "timezone": "Europe/Berlin",

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^versions/openssl\\.txt$/"],
      "matchStrings": ["^(?<currentValue>openssl-[0-9]+\\.[0-9]+\\.[0-9]+)$"],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "openssl/openssl",
      "versioningTemplate": "regex"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^versions/ngtcp2\\.txt$/"],
      "matchStrings": ["^(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)$"],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "ngtcp2/ngtcp2",
      "versioningTemplate": "regex"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^versions/nghttp3\\.txt$/"],
      "matchStrings": ["^(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)$"],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "ngtcp2/nghttp3",
      "versioningTemplate": "regex"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "matchFileNames": ["versions/openssl.txt"],
      "matchDepNames": ["openssl/openssl"],
      "allowedVersions": "<4.0.0"
    }
  ]
}
