{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["every weekday", "on saturday", "on sunday"],
  "automergeType": "branch",
  "automerge": true,
  "automergeStrategy": "merge-commit",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "(^|/)versions/openssl\\.txt$"
      ],
      "matchStrings": [
        "openssl-(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "extractVersionTemplate": "^openssl-(?<version>.*)$",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "(^|/)versions/ngtcp2\\.txt$"
      ],
      "matchStrings": [
        "(?m)^\\s*v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "ngtcp2",
      "packageNameTemplate": "ngtcp2/ngtcp2",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "(^|/)versions/nghttp3\\.txt$"
      ],
      "matchStrings": [
        "(?m)^\\s*v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "nghttp3",
      "packageNameTemplate": "ngtcp2/nghttp3",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "matchFileNames": ["versions/openssl.txt"],
      "matchDepNames": ["openssl"],
      "allowedVersions": "<4.0.0"
    },
    {
      "groupName": "QUIC stack",
      "matchFileNames": [
        "versions/ngtcp2.txt",
        "versions/nghttp3.txt"
      ],
      "automerge": true
    }
  ]
}
