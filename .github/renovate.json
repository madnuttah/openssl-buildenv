{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],

  "timezone": "Europe/Berlin",
  "schedule": ["at any time"],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>openssl-[0-9]+\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl/openssl",
      "extractVersionTemplate": "^openssl-(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/ngtcp2\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "ngtcp2/ngtcp2",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/nghttp3\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "ngtcp2/nghttp3",
      "versioningTemplate": "semver"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "matchFileNames": ["versions/openssl.txt"],
      "matchDepNames": ["openssl/openssl"],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchFileNames": ["versions/ngtcp2.txt"],
      "matchDepNames": ["ngtcp2/ngtcp2"],
      "allowedVersions": "<2.0.0"
    },
    {
      "matchFileNames": ["versions/nghttp3.txt"],
      "matchDepNames": ["ngtcp2/nghttp3"],
      "allowedVersions": "<2.0.0"
    }
  ]
}
