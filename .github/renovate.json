{
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "default:pinDigests",
    "default:automergeDigest"
  ],

  "github-actions": {
    "enabled": true
  },

  "docker": {
    "pinDigests": true,
    "digest": { "enabled": true }
  },

  "regexManagers": [
    {
      "fileMatch": ["buildvars", "\\.sh$"],
      "matchStrings": [],
      "datasourceTemplate": "null"
    }
  ],

  "packageRules": [
    {
      "matchFileNames": ["buildvars"],
      "enabled": false
    },
    {
      "matchFileNames": [".github/workflows/**"],
      "matchManagers": ["regex"],
      "enabled": false
    },
    {
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["ubuntu", "debian", "alpine"],
      "versioning": "semver"
    },
    {
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],

  "ignorePaths": ["docker/old-files/"]
}
